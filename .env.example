# 🚢 Titanic Survival Prediction - Environment Configuration Template
# This file serves as a template for local development and production deployment on AWS EC2.

# --- MLflow Configuration ---
# The tracking URI for your MLflow Tracking Server (e.g., http://your-ec2-public-ip:5000)
MLFLOW_TRACKING_URI=http://localhost:5000

# --- AWS Infrastructure Secrets ---
# Ensure these are managed via AWS IAM Roles when deploying to EC2 in production
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_DEFAULT_REGION=us-east-1

# --- FastAPI Server Configuration ---
# The port the application will bind to on the EC2 instance
SERVER_PORT=8000

# --- Application Settings ---
# The path where the trained model artifacts will be loaded from
MODEL_ARTIFACT_PATH=./models/titanic_random_forest.pkl

# Deployment Environment (development, staging, production)
APP_ENV=development